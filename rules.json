          ],
          "pi_level": "HIGH",
          "description": "계약서 - 계약 당사자 이름/조건 포함"
        },
        "예창패/2025": {
          "patterns": [
            "*예비창업패키지*2025*", "*린스타트업*", "*심사의견서*",
            "*Koreigner*예비창업*", "예창패 공고*"
          ],
          "pi_level": "MEDIUM",
          "description": "예창패 2025 - 대표자 이름 포함 사업계획서"
        },
        "예창패/2026": {
          "patterns": [
            "*예비창업패키지*2026*", "2026*예비창업*", "*2026*예창패*",
            "2026*business*plan*", "*2026_business*plan*",
            "*예창패*사업계획서*", "*예창패*증빙*"
          ],
          "pi_level": "MEDIUM",
          "description": "예창패 2026 - 대표자 이름 포함 사업계획서"
        },
        "창업중심대학": {
          "patterns": [
            "*창업중심대학*", "*캠퍼스타운*", "*창업경진대회*",
            "*시대창*", "*아이디어 사업화*", "*동대문구*창업*",
            "*혁신창업리그*", "*정주영*창업*",
            "*창중대*", "*초기창업패키지*", "*접수증*"
          ],
          "pi_level": "MEDIUM",
          "description": "창업 지원 프로그램 문서 - 이름 포함 가능"
        },
        "YC": {
          "patterns": [
            "YC*", "*YC*펀드*", "*co-founder matching*"
