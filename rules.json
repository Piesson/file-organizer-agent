          "pi_level": "LOW",
          "description": "YC 관련 자료 - 공개용 덱/가이드"
        },
        "개인서류": {
          "patterns": [
            "*급여명세서*", "*재학증명서*", "*소득확인*", "*경력증명서*",
            "*휴학증명서*", "*소득금액증명*", "*졸업증명서*", "*신분증*",
            "*.p12", "*수료증*",
            "*카드이용내역*", "*직불카드*", "*청년전세임대*", "*개인정보수집*"
