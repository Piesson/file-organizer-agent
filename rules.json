          "pi_level": "MEDIUM",
          "description": "투자 관련 서류 - 재정 조건/당사자 정보 포함"
        },
        "채용": {
          "patterns": [
            "*Resume*", "*이력서*", "CV_*"
          ],
          "pi_level": "LOW",
          "description": "채용 서류 - 공개 목적으로 작성된 이력서"
        }
