{
  "categories": {
    "Business": {
      "description": "사업 문서, 계약서, 재무 서류",
      "subfolders": {
        "Koddy_Inc/법인설립": {
          "patterns": [
            "*Certificate*", "*Incorporation*", "SIGNED*", "*IRS*",
            "*Delaware*", "*FranchiseTax*", "*certificate of insurance*",
            "ps-form-*", "*CSC*", "*사업자등록증*"
          ],
          "pi_level": "HIGH",
          "description": "법인 등기 서류 - 회사명/세금ID/법적 신원 포함"
        },
        "Koddy_Inc/재무": {
          "patterns": [
            "*Invoice*", "*세금계산서*", "*Wire-Details*",
            "*mercury-backup*", "*견적서*", "*송금내역*"
          ],
          "pi_level": "HIGH",
          "description": "재정 서류 - 파일명에 금융정보/계좌 포함"
        },
        "Koddy_Inc/계약서": {
          "patterns": [
            "*MARU*계약서*", "*임대차*", "*멤버십 계약서*",
