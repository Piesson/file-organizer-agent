  "boundary_rules": {
    "comment": "경계 케이스 우선순위 규칙 (위에서 아래 순서로 적용)",
    "rules": [
      "증명사진(김경빈*.jpg) → Business/개인서류 (Media/개인사진 아님)",
      "코딩로그 PDF(*__코딩로그_*) → Dev/코딩로그 (Resources 아님)",
      "Hinton/Kurzweil 사진 → Resources/AI (Media 아님, 연구 자료)",
      "CapCut Materials 내 mp4 → Media/동영상 (Dev 아님)",
      "Resources/스타트업 내 사업계획서 → Business (Resources 아님)",
      "*.jpg/*.png 파일: Business 관련 패턴 우선 → Business/개인서류",
      "*.jpg/*.png 파일: Dev 관련 패턴 우선 → Dev/에셋",
      "나머지 이미지 → Media/기타이미지",
      "*.p12: 개인서류 패턴 없으면 → Dev/인증키 (Business/개인서류 우선)"
    ]
  },
  "delete": {
    "description": "삭제 대상 (설치 완료된 파일)",
    "patterns": ["*.dmg"],
    "requireConfirmation": true
  },
  "settings": {
    "targetFolder": "~/Downloads",
    "keepDuplicates": true,
    "preserveTimestamps": true
  }
}
