    "Dev": {
      "description": "앱 빌드, 목업, 개발 에셋, 인증키",
      "subfolders": {
        "코딩로그": {
          "patterns": ["*__코딩로그_*"],
          "pi_level": "LOW",
          "description": "코딩 작업 기록 - 기술 내용 중심"
        },
        "목업": {
          "patterns": [
            "apple-iphone-*", "*mockup*", "AppScreens-*",
            "Animated-iPhone-*"
          ],
          "pi_level": "NONE",
          "description": "앱 목업 이미지 - 공개 디자인 파일"
        },
        "에셋": {
          "patterns": [
            "*.svg", "*_logo*", "*icon*", "Notioly*",
            "Notion Icons*", "*startup.png*", "*poster*", "kbim*.png",
            "photoofkb*", "photoofme*",
            "*logo*.png", "*logo*.jpg", "google*.html",
            "admin_*.png", "admin_*.jpg"
          ],
          "pi_level": "NONE",
          "description": "개발 에셋 - 공개 이미지/아이콘"
        },
        "배포": {
          "patterns": ["*.aab", "*.apk", "*.ipa", "client.o", "koddies-*.aab"],
          "pi_level": "NONE",
          "description": "앱 빌드 파일 - 배포용 바이너리"
        },
        "인증키": {
          "patterns": [
            "AuthKey*", "PushKey*", "*firebase*adminsdk*.json",
            "*.p8"
          ],
          "pi_level": "HIGH",
          "description": "보안 인증키 - Apple/Firebase 서버 자격증명"
        },
        "데이터": {
          "patterns": [
            "*.db", "*.csv", "logs_result.json",
            "*Edge Requests*", "*.xml", "responses.*",
            "*고객*정리*.xlsx", "*User*.xlsx", "*FB 유저*",
            "*.heapsnapshot", "*-diagnostics.json"
          ],
          "pi_level": "MEDIUM",
          "description": "데이터 파일 - 사용자 데이터 포함 가능"
        }
      },
      "patterns": [
        "*.aab", "*.apk", "apple-iphone-*", "AppScreens-*",
        "AuthKey*", "PushKey*", "*firebase*.json", "*.db",
        "*.xml", "*__코딩로그_*"
      ]
    },
